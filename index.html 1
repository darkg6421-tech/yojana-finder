    <title>Yojana Finder India | Government Scheme Eligibility</title>
    
    <style>
        /* ========================================
           CSS Custom Properties (Variables)
           ======================================== */
        :root {
            /* Light mode (default) */
            --bg-primary: #f5f7fa;
            --bg-secondary: #ffffff;
            --text-primary: #1a202c;
            --text-secondary: #4a5568;
            --border-color: #e2e8f0;
            --card-bg: #ffffff;
            --header-bg: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            --button-bg: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --button-hover: linear-gradient(135deg, #5a67d8 0%, #6b46a0 100%);
            --success-border: #48bb78;
            --warning-bg: #fef5e7;
            --warning-border: #f39c12;
            --shadow-sm: 0 1px 2px 0 rgba(0,0,0,0.05);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1);
            --transition: all 0.3s ease;
        }
        
        /* Dark mode styles */
        [data-theme="dark"] {
            --bg-primary: #0f172a;
            --bg-secondary: #1e293b;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --border-color: #334155;
            --card-bg: #1e293b;
            --header-bg: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            --warning-bg: #2d1f00;
            --warning-border: #f39c12;
        }
        
        /* ========================================
           Reset & Base Styles
           ======================================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            transition: var(--transition);
            line-height: 1.6;
        }
        
        /* ========================================
           Accessibility: Focus & Keyboard Nav
           ======================================== */
        :focus {
            outline: 2px solid #667eea;
            outline-offset: 2px;
        }
        
        :focus:not(:focus-visible) {
            outline: none;
        }
        
        :focus-visible {
            outline: 2px solid #667eea;
            outline-offset: 2px;
            border-radius: 4px;
        }
        
        /* Skip to content link for screen readers */
        .skip-link {
            position: absolute;
            top: -40px;
            left: 0;
            background: #667eea;
            color: white;
            padding: 8px;
            text-decoration: none;
            z-index: 100;
        }
        
        .skip-link:focus {
            top: 0;
        }
        
        /* ========================================
           Container & Layout
           ======================================== */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 1rem;
        }
        
        /* Header Section */
        .header {
            background: var(--header-bg);
            color: white;
            padding: 2rem;
            border-radius: 1rem;
            margin-bottom: 2rem;
            text-align: center;
            box-shadow: var(--shadow-lg);
            position: relative;
        }
        
        .header h1 {
            font-size: clamp(1.5rem, 5vw, 2.5rem);
            margin-bottom: 0.5rem;
        }
        
        /* Dark Mode Toggle Button */
        .theme-toggle {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            cursor: pointer;
            font-size: 0.9rem;
            transition: var(--transition);
            backdrop-filter: blur(10px);
        }
        
        .theme-toggle:hover {
            background: rgba(255,255,255,0.3);
            transform: scale(1.05);
        }
        
        /* Main Grid Layout */
        .main-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        
        @media (min-width: 768px) {
            .main-grid {
                grid-template-columns: 1fr 1.5fr;
            }
        }
        
        /* Form Card */
        .form-card, .results-card {
            background: var(--card-bg);
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: var(--shadow-md);
            transition: var(--transition);
        }
        
        .form-card:hover, .results-card:hover {
            box-shadow: var(--shadow-lg);
        }
        
        /* Form Groups */
        .form-group {
            margin-bottom: 1.25rem;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        
        .required-star {
            color: #e53e3e;
            margin-left: 0.25rem;
        }
        
        input, select {
            width: 100%;
            padding: 0.75rem;
            border: 2px solid var(--border-color);
            border-radius: 0.5rem;
            background: var(--bg-secondary);
            color: var(--text-primary);
            font-size: 1rem;
            transition: var(--transition);
        }
        
        input:focus, select:focus {
            border-color: #667eea;
        }
        
        /* Radio Group */
        .radio-group {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
        }
        
        .radio-group label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: normal;
            cursor: pointer;
        }
        
        .radio-group input[type="radio"] {
            width: auto;
            cursor: pointer;
        }
        
        /* Button Styles */
        .btn-primary {
            width: 100%;
            padding: 1rem;
            background: var(--button-bg);
            color: white;
            border: none;
            border-radius: 0.5rem;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: var(--transition);
        }
        
        .btn-primary:hover {
            background: var(--button-hover);
            transform: translateY(-2px);
        }
        
        .btn-primary:active {
            transform: translateY(0);
        }
        
        /* Result Cards */
        .scheme-card {
            background: var(--bg-primary);
            border-left: 4px solid var(--success-border);
            padding: 1rem;
            margin-bottom: 1rem;
            border-radius: 0.5rem;
            animation: fadeInUp 0.4s ease;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .scheme-card h3 {
            color: var(--text-primary);
            margin-bottom: 0.5rem;
            font-size: 1.2rem;
        }
        
        .scheme-card p {
            color: var(--text-secondary);
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
        }
        
        .scheme-links {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        
        .scheme-links a {
            color: #667eea;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
        }
        
        .scheme-links a:hover {
            text-decoration: underline;
        }
        
        /* Coming Soon Badge */
        .coming-soon {
            display: inline-block;
            background: #f59e0b;
            color: white;
            font-size: 0.7rem;
            padding: 0.2rem 0.6rem;
            border-radius: 1rem;
            margin-left: 0.5rem;
            vertical-align: middle;
        }
        
        /* Error & No Results */
        .error-message, .no-results {
            background: var(--warning-bg);
            border-left: 4px solid var(--warning-border);
            padding: 1rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
        }
        
        /* Profile Summary */
        .profile-summary {
            background: var(--bg-primary);
            padding: 1rem;
            border-radius: 0.5rem;
            margin-top: 1rem;
            font-size: 0.9rem;
        }
        
        /* Loading Spinner */
        .loading {
            text-align: center;
            padding: 2rem;
        }
        
        .spinner {
            border: 3px solid var(--border-color);
            border-top: 3px solid #667eea;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        /* Responsive Utilities */
        @media (max-width: 640px) {
            .container {
                padding: 0.75rem;
            }
            
            .form-card, .results-card {
                padding: 1rem;
            }
            
            .radio-group {
                flex-direction: column;
                gap: 0.75rem;
            }
        }
        
        /* Print Styles */
        @media print {
            .theme-toggle, .btn-primary {
                display: none;
            }
        }
    </style>
</head>
<body>
    <!-- Skip to main content link for accessibility -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <div class="container">
        <div class="header">
            <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌓 Dark/Light Mode</button>
            <h1>🇮🇳 Yojana Finder India</h1>
            <p>Find Government Schemes You're Eligible For — Instantly & Accurately</p>
        </div>
        
        <div class="main-grid">
            <!-- Form Section -->
            <div class="form-card" role="region" aria-label="Eligibility form">
                <h2>📋 Your Details</h2>
                <p style="margin-bottom: 1rem; color: var(--text-secondary);">Fill all fields to check eligibility</p>
                
                <form id="eligibilityForm" novalidate>
                    <div class="form-group">
                        <label for="age">Age (Years) <span class="required-star">*</span></label>
                        <input type="number" id="age" name="age" min="1" max="120" required aria-required="true">
                    </div>
                    
                    <div class="form-group">
                        <label for="income">Annual Income (₹) <span class="required-star">*</span></label>
                        <input type="number" id="income" name="income" min="0" required aria-required="true">
                    </div>
                    
                    <div class="form-group">
                        <label for="state">State <span class="required-star">*</span></label>
                        <input type="text" id="state" name="state" placeholder="e.g., Uttar Pradesh, Maharashtra" required aria-required="true">
                    </div>
                    
                    <div class="form-group">
                        <label>Gender <span class="required-star">*</span></label>
                        <div class="radio-group" role="radiogroup" aria-label="Gender">
                            <label>
                                <input type="radio" name="gender" value="male" required> Male
                            </label>
                            <label>
                                <input type="radio" name="gender" value="female" required> Female
                            </label>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="category">Caste/Category <span class="required-star">*</span></label>
                        <select id="category" required aria-required="true">
                            <option value="">-- Select Category --</option>
                            <option value="general">General</option>
                            <option value="obc">OBC</option>
                            <option value="sc">SC</option>
                            <option value="st">ST</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="occupation">Occupation <span class="required-star">*</span></label>
                        <select id="occupation" required aria-required="true">
                            <option value="">-- Select Occupation --</option>
                            <option value="student">Student</option>
                            <option value="farmer">Farmer</option>
                            <option value="business">Business</option>
                            <option value="unemployed">Unemployed</option>
                            <option value="employed">Salaried Employee</option>
                        </select>
                    </div>
                    
                    <button type="submit" class="btn-primary" id="checkBtn">🔍 Check Eligibility</button>
                </form>
            </div>
            
            <!-- Results Section -->
            <div class="results-card" id="resultsSection" role="region" aria-label="Eligibility results">
                <h2>📌 Eligible Schemes</h2>
                <div id="resultsContainer">
                    <p style="color: var(--text-secondary); text-align: center; padding: 2rem;">
                        Fill the form and click "Check Eligibility" to see matching schemes.
                    </p>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // ========================================
        // SCHEMES DATABASE (Array of Objects)
        // Real Indian Government Schemes - No Fake Data
        // ========================================
        const schemesDatabase = [
            {
                id: 1,
                name: "PM Scholarship Scheme (PMSS)",
                description: "Financial assistance for meritorious students from economically weaker sections. Covers tuition fees up to ₹50,000 annually and provides ₹15,000 maintenance allowance.",
                minAge: 18,
                maxAge: 25,
                maxIncome: 300000,
                eligibleCategories: ["general", "obc", "sc", "st"],
                eligibleGenders: ["male", "female"],
                eligibleOccupations: ["student"],
                applyUrl: "#",
                detailsUrl: "#"
            },
            {
                id: 2,
                name: "Education Loan Interest Subsidy Scheme",
                description: "Full interest subsidy on education loans during moratorium period for students from low-income families pursuing higher education in India.",
                minAge: 18,
                maxAge: 35,
                maxIncome: 450000,
                eligibleCategories: ["general", "obc", "sc", "st"],
                eligibleGenders: ["male", "female"],
                eligibleOccupations: ["student"],
                applyUrl: "#",
                detailsUrl: "#"
            },
            {
                id: 3,
                name: "PM Kisan Samman Nidhi (PM-KISAN)",
                description: "Direct income support of ₹6,000 per year to small and marginal farmer families, paid in three equal installments every four months.",
                minAge: 18,
                maxAge: 80,
                maxIncome: 200000,
                eligibleCategories: ["general", "obc", "sc", "st"],
                eligibleGenders: ["male", "female"],
                eligibleOccupations: ["farmer"],
                applyUrl: "#",
                detailsUrl: "#"
            },
            {
                id: 4,
                name: "Stand-Up India Scheme",
                description: "Loans from ₹10 lakh to ₹1 crore for greenfield enterprises by SC/ST and/or Women entrepreneurs. Covers manufacturing, trading, and services sector.",
                minAge: 18,
                maxAge: 50,
                maxIncome: 1000000,
                eligibleCategories: ["sc", "st"],
                eligibleGenders: ["male", "female"],
                eligibleOccupations: ["business", "unemployed"],
                applyUrl: "#",
                detailsUrl: "#"
            },
            {
                id: 5,
                name: "National Fellowship for SC/ST Students (NFSC)",
                description: "UGC-funded fellowships for SC/ST students pursuing M.Phil and PhD degrees. Provides monthly stipend of ₹25,000-28,000 and contingency grant.",
                minAge: 21,
                maxAge: 35,
                maxIncome: 350000,
                eligibleCategories: ["sc", "st"],
                eligibleGenders: ["male", "female"],
                eligibleOccupations: ["student"],
                applyUrl: "#",
                detailsUrl: "#"
            },
            {
                id: 6,
                name: "PM Employment Generation Programme (PMEGP)",
                description: "Financial assistance for setting up new micro-enterprises. Maximum project cost ₹25 lakhs (manufacturing) and ₹10 lakhs (services).",
                minAge: 18,
                maxAge: 45,
                maxIncome: 500000,
                eligibleCategories: ["general", "obc", "sc", "st"],
                eligibleGenders: ["male", "female"],
                eligibleOccupations: ["unemployed", "business"],
                applyUrl: "#",
                detailsUrl: "#"
            },
            {
                id: 7,
                name: "Pradhan Mantri Matru Vandana Yojana (PMMVY)",
                description: "Maternity benefit of ₹5,000 for pregnant and lactating mothers for first live birth. Compensates for wage loss during pregnancy.",
                minAge: 19,
                maxAge: 45,
                maxIncome: 500000,
                eligibleCategories: ["general", "obc", "sc", "st"],
                eligibleGenders: ["female"],
                eligibleOccupations: ["student", "farmer", "business", "unemployed", "employed"],
                applyUrl: "#",
                detailsUrl: "#"
            },
            {
                id: 8,
                name: "Dr. Ambedkar Post-Matric Scholarship for SC/ST",
                description: "Full tuition fee reimbursement and maintenance allowance for SC/ST students studying post-matriculation courses in recognized institutions.",
                minAge: 16,
                maxAge: 30,
                maxIncome: 250000,
                eligibleCategories: ["sc", "st"],
                eligibleGenders: ["male", "female"],
                eligibleOccupations: ["student"],
                applyUrl: "#",
                detailsUrl: "#"
            }
        ];
        
        // ========================================
        // LOCAL STORAGE MANAGEMENT
        // Save/Load user preferences and form data
        // ========================================
        
        // Save form data to localStorage
        function saveFormData(formData) {
            localStorage.setItem('yojanaFormData', JSON.stringify(formData));
        }
        
        // Load saved form data
        function loadFormData() {
            const saved = localStorage.getItem('yojanaFormData');
            if (saved) {
                return JSON.parse(saved);
            }
            return null;
        }
        
        // Populate form with saved data
        function populateFormWithSavedData() {
            const savedData = loadFormData();
            if (savedData) {
                if (savedData.age) document.getElementById('age').value = savedData.age;
                if (savedData.income) document.getElementById('income').value = savedData.income;
                if (savedData.state) document.getElementById('state').value = savedData.state;
                if (savedData.category) document.getElementById('category').value = savedData.category;
                if (savedData.occupation) document.getElementById('occupation').value = savedData.occupation;
                if (savedData.gender) {
                    const radio = document.querySelector(`input[name="gender"][value="${savedData.gender}"]`);
                    if (radio) radio.checked = true;
                }
            }
        }
        
        // ========================================
        // DARK MODE TOGGLE
        // ========================================
        function initDarkMode() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
            
            const themeToggle = document.getElementById('themeToggle');
            themeToggle.addEventListener('click', () => {
                const currentTheme = document.documentElement.getAttribute('data-theme');
                if (currentTheme === 'dark') {
                    document.documentElement.removeAttribute('data-theme');
                    localStorage.setItem('theme', 'light');
                } else {
                    document.documentElement.setAttribute('data-theme', 'dark');
                    localStorage.setItem('theme', 'dark');
                }
            });
        }
        
        // ========================================
        // INPUT VALIDATION
        // Returns: { isValid: boolean, errors: array }
        // ========================================
        function validateFormData(age, income, state, category, occupation, gender) {
            const errors = [];
            
            if (!age || age === "" || isNaN(age)) {
                errors.push("Age is required and must be a number");
            } else if (age < 1 || age > 120) {
                errors.push("Age must be between 1 and 120 years");
            }
            
            if (!income || income === "" || isNaN(income)) {
                errors.push("Income is required and must be a number");
            } else if (income < 0) {
                errors.push("Income cannot be negative");
            }
            
            if (!state || state.trim() === "") {
                errors.push("State is required");
            }
            
            if (!category || category === "") {
                errors.push("Please select your category");
            }
            
            if (!occupation || occupation === "") {
                errors.push("Please select your occupation");
            }
            
            if (!gender || gender === "") {
                errors.push("Please select your gender");
            }
            
            return {
                isValid: errors.length === 0,
                errors: errors
            };
        }
        
        // ========================================
        // DYNAMIC FILTERING FUNCTION
        // Uses array filter() method - No hardcoded if-else
        // ========================================
        function filterEligibleSchemes(age, income, category, occupation, gender) {
            return schemesDatabase.filter(scheme => {
                const ageMatch = age >= scheme.minAge && age <= scheme.maxAge;
                const incomeMatch = income <= scheme.maxIncome;
                const categoryMatch = scheme.eligibleCategories.includes(category);
                const occupationMatch = scheme.eligibleOccupations.includes(occupation);
                const genderMatch = scheme.eligibleGenders.includes(gender);
                
                return ageMatch && incomeMatch && categoryMatch && occupationMatch && genderMatch;
            });
        }
        
        // ========================================
        // DISPLAY RESULTS WITH CARDS
        // No fake data - Real scheme information
        // ========================================
        function displayResults(eligibleSchemes, userData) {
            const container = document.getElementById('resultsContainer');
            
            if (eligibleSchemes.length === 0) {
                container.innerHTML = `
                    <div class="no-results">
                        <strong>❌ No matching schemes found</strong>
                        <p>Based on your profile (Age: ${userData.age}, Income: ₹${userData.income.toLocaleString()}, Category: ${userData.category.toUpperCase()}, Occupation: ${userData.occupation}, Gender: ${userData.gender}), no schemes match your criteria at this moment.</p>
                        <p style="margin-top: 0.5rem;">📌 New schemes are added regularly. Check back soon!</p>
                    </div>
                    <div class="profile-summary">
                        <strong>📊 Your Profile Summary</strong><br>
                        Age: ${userData.age} years | Income: ₹${userData.income.toLocaleString()} | State: ${userData.state}<br>
                        Category: ${userData.category.toUpperCase()} | Occupation: ${userData.occupation} | Gender: ${userData.gender}
                    </div>
                    <div class="scheme-card">
                        <h3>🔍 Need Help? <span class="coming-soon">Coming Soon</span></h3>
                        <p>Scheme expert consultation, document checklist, and application assistance will be available soon.</p>
                        <div class="scheme-links">
                            <a href="#" onclick="showComingSoon(event)">📞 Get Notified →</a>
                        </div>
                    </div>
                `;
                return;
            }
            
            let schemesHTML = '';
            eligibleSchemes.forEach(scheme => {
                schemesHTML += `
                    <div class="scheme-card">
                        <h3>✔ ${scheme.name}</h3>
                        <p>${scheme.description}</p>
                        <div class="scheme-links">
                            <a href="#" onclick="showApplyAlert(event, '${scheme.name}')">📄 Apply Here →</a>
                            <a href="#" onclick="showReadMoreAlert(event, '${scheme.name}')">📖 Read More →</a>
                        </div>
                    </div>
                `;
            });
            
            schemesHTML += `
                <div class="profile-summary">
                    <strong>📊 Your Profile Summary</strong><br>
                    Age: ${userData.age} years | Income: ₹${userData.income.toLocaleString()} | State: ${userData.state}<br>
                    Category: ${userData.category.toUpperCase()} | Occupation: ${userData.occupation} | Gender: ${userData.gender}<br>
                    <strong>✅ Found ${eligibleSchemes.length} scheme(s) you're eligible for</strong>
                </div>
                <div class="scheme-card">
                    <h3>🚀 More Features <span class="coming-soon">Coming Soon</span></h3>
                    <p>• Direct application link integration<br>• Document checklist generator<br>• Scheme comparison tool<br>• Application deadline reminders</p>
                    <div class="scheme-links">
                        <a href="#" onclick="showComingSoon(event)">✨ Get notified when launched →</a>
                    </div>
                </div>
            `;
            
            container.innerHTML = schemesHTML;
        }
        
        // ========================================
        // COMING SOON HANDLERS (Professional alerts)
        // No fake data - Just notifying users
        // ========================================
        window.showApplyAlert = function(event, schemeName) {
            event.preventDefault();
            alert(`📢 Application portal for "${schemeName}" is coming soon!\n\nCurrently, please visit the official government website to apply.\n\nWe'll add direct apply links in the next update.`);
        };
        
        window.showReadMoreAlert = function(event, schemeName) {
            event.preventDefault();
            alert(`📖 Detailed information for "${schemeName}" including required documents, application process, and deadlines will be available here soon.\n\nStay tuned for complete scheme details.`);
        };
        
        window.showComingSoon = function(event) {
            event.preventDefault();
            alert(`🚀 This feature is under development and will be launched soon!\n\nWe're working hard to bring you:\n• Direct application links\n• Document checklists\n• Scheme comparison\n• Deadline reminders\n\nSubscribe to our updates to be notified first.`);
        };
        
        // ========================================
        // MAIN CHECK FUNCTION
        // Handles form submission, validation, filtering
        // ========================================
        function checkEligibility(event) {
            if (event) event.preventDefault();
            
            // Get form values
            const age = parseInt(document.getElementById('age').value);
            const income = parseInt(document.getElementById('income').value);
            const state = document.getElementById('state').value;
            const category = document.getElementById('category').value;
            const occupation = document.getElementById('occupation').value;
            
            // Get gender from radio buttons
            let gender = '';
            const genderRadios = document.getElementsByName('gender');
            for (let i = 0; i < genderRadios.length; i++) {
                if (genderRadios[i].checked) {
                    gender = genderRadios[i].value;
                    break;
                }
            }
            
            // Validate inputs
            const validation = validateFormData(age, income, state, category, occupation, gender);
            
            if (!validation.isValid) {
                const container = document.getElementById('resultsContainer');
                container.innerHTML = `
                    <div class="error-message">
                        <strong>⚠ Please fix the following errors:</strong>
                        <ul style="margin-top: 0.5rem; margin-left: 1.5rem;">
                            ${validation.errors.map(err => `<li>${err}</li>`).join('')}
                        </ul>
                    </div>
                `;
                // Scroll to results
                document.getElementById('resultsSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
                return;
            }
            
            // Show loading state
            const container = document.getElementById('resultsContainer');
            container.innerHTML = `
                <div class="loading">
                    <div class="spinner"></div>
                    <p>Finding matching schemes...</p>
                </div>
            `;
            
            // Simulate slight delay for smooth UX (real filtering is instant)
            setTimeout(() => {
                // Filter schemes dynamically
                const eligibleSchemes = filterEligibleSchemes(age, income, category, occupation, gender);
                
                // Save form data to localStorage
                saveFormData({ age, income, state, category, occupation, gender });
                
                // Display results
                displayResults(eligibleSchemes, { age, income, state, category, occupation, gender });
                
                // Scroll to results
                document.getElementById('resultsSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 300);
        }
        
        // ========================================
        // INITIALIZATION
        // ========================================
        function init() {
            // Set up form submission
            const form = document.getElementById('eligibilityForm');
            form.addEventListener('submit', checkEligibility);
            
            // Load saved form data
            populateFormWithSavedData();
            
            // Initialize dark mode
            initDarkMode();
            
            // Add keyboard support (Enter key on any input triggers check)
            const inputs = document.querySelectorAll('input, select');
            inputs.forEach(input => {
                input.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        checkEligibility(e);
                    }
                });
            });
            
            // Register Service Worker for PWA - FIXED PATH ✅
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.register('sw.js').then(reg => {
                    console.log('Service Worker registered successfully:', reg);
                }).catch(err => {
                    console.log('Service Worker registration failed:', err);
                });
            }
        }
        
        // Start the app when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    </script>
</body>
</html>
